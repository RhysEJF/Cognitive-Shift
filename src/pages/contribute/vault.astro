---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Image Vault — The Cognitive Shift" description="Upload images for articles and publications.">
  <div class="vault-page">
    <!-- Loading state -->
    <div id="vault-loading" class="vault-loading">
      <div class="page-header">
        <div class="section-label">Contributor Tools</div>
        <h1 class="page-title">Image Vault</h1>
        <p class="page-subtitle">Checking authentication...</p>
      </div>
    </div>

    <!-- Unauthenticated state -->
    <div id="vault-login" class="vault-login" style="display: none;">
      <div class="page-header">
        <div class="section-label">Contributor Tools</div>
        <h1 class="page-title">Image Vault</h1>
        <p class="page-subtitle">Upload images for use in Keystatic articles and publications.</p>
      </div>
      <div class="vault-login-card">
        <p class="vault-login-text">Sign in with your GitHub account to access the upload tool.</p>
        <a href="/api/upload/auth/login" class="vault-github-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Sign in with GitHub
        </a>
      </div>
    </div>

    <!-- Authenticated state -->
    <div id="vault-main" class="vault-main" style="display: none;">
      <div class="vault-header">
        <div class="vault-header-left">
          <div class="section-label">Contributor Tools</div>
          <h1 class="page-title" style="margin-bottom: 0;">Image Vault</h1>
        </div>
        <div class="vault-user">
          <img id="vault-avatar" src="" alt="" class="vault-avatar" />
          <span id="vault-username" class="vault-username"></span>
          <form method="POST" action="/api/upload/auth/logout" style="display:inline;">
            <button type="submit" class="vault-logout-btn">Sign out</button>
          </form>
        </div>
      </div>

      <div class="gold-rule"></div>

      <!-- Upload controls -->
      <div class="vault-upload-section">
        <div class="vault-category-row">
          <label class="vault-label" for="vault-category">Category</label>
          <select id="vault-category" class="vault-select">
            <option value="articles">Articles</option>
            <option value="authors">Authors</option>
            <option value="publications">Publications</option>
            <option value="general">General</option>
          </select>
        </div>

        <div id="vault-dropzone" class="vault-dropzone">
          <div class="vault-dropzone-content">
            <svg class="vault-dropzone-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
            </svg>
            <p class="vault-dropzone-text">Drag &amp; drop an image here</p>
            <p class="vault-dropzone-hint">JPEG, PNG, WebP, or GIF &middot; Max 10 MB</p>
            <label class="vault-browse-btn">
              Browse files
              <input type="file" id="vault-file-input" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none;" />
            </label>
          </div>
        </div>

        <!-- Progress bar -->
        <div id="vault-progress" class="vault-progress" style="display:none;">
          <div class="vault-progress-bar">
            <div id="vault-progress-fill" class="vault-progress-fill"></div>
          </div>
          <p id="vault-progress-text" class="vault-progress-text">Uploading...</p>
        </div>

        <!-- Error display -->
        <div id="vault-error" class="vault-error" style="display:none;"></div>

        <!-- Success result -->
        <div id="vault-result" class="vault-result" style="display:none;">
          <div class="vault-result-label">CDN URL</div>
          <div class="vault-result-url-row">
            <input id="vault-result-url" type="text" class="vault-result-url" readonly />
            <button id="vault-copy-btn" class="vault-copy-btn" type="button">Copy</button>
          </div>
          <p id="vault-copy-feedback" class="vault-copy-feedback" style="display:none;">Copied!</p>
        </div>
      </div>

      <!-- Upload history -->
      <div id="vault-history" class="vault-history" style="display:none;">
        <div class="gold-rule"></div>
        <h2 class="vault-history-title">Recent Uploads</h2>
        <div id="vault-history-list" class="vault-history-list"></div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    var loadingEl = document.getElementById('vault-loading');
    var loginEl = document.getElementById('vault-login');
    var mainEl = document.getElementById('vault-main');
    var avatarEl = document.getElementById('vault-avatar');
    var usernameEl = document.getElementById('vault-username');
    var dropzone = document.getElementById('vault-dropzone');
    var fileInput = document.getElementById('vault-file-input');
    var categorySelect = document.getElementById('vault-category');
    var progressEl = document.getElementById('vault-progress');
    var progressFill = document.getElementById('vault-progress-fill');
    var progressText = document.getElementById('vault-progress-text');
    var errorEl = document.getElementById('vault-error');
    var resultEl = document.getElementById('vault-result');
    var resultUrl = document.getElementById('vault-result-url');
    var copyBtn = document.getElementById('vault-copy-btn');
    var copyFeedback = document.getElementById('vault-copy-feedback');
    var historyEl = document.getElementById('vault-history');
    var historyList = document.getElementById('vault-history-list');

    var uploads = [];

    // Check auth status on load
    fetch('/api/upload/session')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loadingEl.style.display = 'none';
        if (data.authenticated) {
          avatarEl.src = data.user.avatar_url;
          avatarEl.alt = data.user.login;
          usernameEl.textContent = data.user.login;
          mainEl.style.display = 'block';
        } else {
          loginEl.style.display = 'block';
        }
      })
      .catch(function() {
        loadingEl.style.display = 'none';
        loginEl.style.display = 'block';
      });

    // Drag and drop
    dropzone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropzone.classList.add('vault-dropzone--active');
    });
    dropzone.addEventListener('dragleave', function() {
      dropzone.classList.remove('vault-dropzone--active');
    });
    dropzone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropzone.classList.remove('vault-dropzone--active');
      var files = e.dataTransfer.files;
      if (files.length > 0) uploadFile(files[0]);
    });

    // File input fallback
    fileInput.addEventListener('change', function() {
      if (fileInput.files.length > 0) {
        uploadFile(fileInput.files[0]);
        fileInput.value = '';
      }
    });

    // Copy button
    copyBtn.addEventListener('click', function() {
      resultUrl.select();
      navigator.clipboard.writeText(resultUrl.value).then(function() {
        copyFeedback.style.display = 'block';
        setTimeout(function() { copyFeedback.style.display = 'none'; }, 2000);
      });
    });

    function uploadFile(file) {
      // Reset UI
      errorEl.style.display = 'none';
      resultEl.style.display = 'none';
      progressEl.style.display = 'block';
      progressFill.style.width = '0%';
      progressText.textContent = 'Uploading...';

      var formData = new FormData();
      formData.append('file', file);
      formData.append('category', categorySelect.value);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/api/upload/file');

      xhr.upload.addEventListener('progress', function(e) {
        if (e.lengthComputable) {
          var pct = Math.round((e.loaded / e.total) * 100);
          progressFill.style.width = pct + '%';
          progressText.textContent = pct + '%';
        }
      });

      xhr.addEventListener('load', function() {
        progressEl.style.display = 'none';
        if (xhr.status >= 200 && xhr.status < 300) {
          var data = JSON.parse(xhr.responseText);
          resultUrl.value = data.url;
          resultEl.style.display = 'block';

          // Add to history
          uploads.unshift({
            url: data.url,
            name: file.name,
            category: categorySelect.value,
            time: new Date().toLocaleTimeString()
          });
          renderHistory();
        } else {
          var msg = 'Upload failed.';
          try {
            var err = JSON.parse(xhr.responseText);
            if (err.error) msg = err.error;
          } catch(e) {}
          showError(msg);
        }
      });

      xhr.addEventListener('error', function() {
        progressEl.style.display = 'none';
        showError('Network error. Please try again.');
      });

      xhr.send(formData);
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
    }

    function renderHistory() {
      if (uploads.length === 0) {
        historyEl.style.display = 'none';
        return;
      }
      historyEl.style.display = 'block';
      historyList.innerHTML = '';
      uploads.forEach(function(item) {
        var row = document.createElement('div');
        row.className = 'vault-history-item';
        row.innerHTML =
          '<span class="vault-history-name">' + escapeHtml(item.name) + '</span>' +
          '<span class="vault-history-category">' + escapeHtml(item.category) + '</span>' +
          '<span class="vault-history-time">' + escapeHtml(item.time) + '</span>' +
          '<button class="vault-history-copy" data-url="' + escapeAttr(item.url) + '">Copy URL</button>';
        historyList.appendChild(row);
      });

      // Copy buttons for history
      historyList.querySelectorAll('.vault-history-copy').forEach(function(btn) {
        btn.addEventListener('click', function() {
          navigator.clipboard.writeText(btn.getAttribute('data-url'));
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = 'Copy URL'; }, 1500);
        });
      });
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function escapeAttr(str) {
      return str.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
  })();
  </script>
</BaseLayout>

<style>
  .vault-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }

  .vault-loading {
    text-align: center;
  }

  .vault-login {
    text-align: center;
  }

  .vault-login-card {
    max-width: 400px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem;
  }

  .vault-login-text {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--cream-muted);
    margin-bottom: 1.5rem;
  }

  .vault-github-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--gold);
    color: var(--bg);
    padding: 0.8rem 1.6rem;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
  }

  .vault-github-btn:hover {
    background: var(--gold-light);
  }

  /* Header */
  .vault-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: 4rem;
  }

  .vault-user {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: 0.5rem;
  }

  .vault-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--border);
  }

  .vault-username {
    font-size: 0.8rem;
    color: var(--cream-dim);
  }

  .vault-logout-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--cream-muted);
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .vault-logout-btn:hover {
    border-color: var(--cream-muted);
    color: var(--cream);
  }

  /* Upload section */
  .vault-upload-section {
    margin-top: 1.5rem;
  }

  .vault-category-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .vault-label {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream-muted);
    flex-shrink: 0;
  }

  .vault-select {
    flex: 1;
    max-width: 200px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--cream);
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.85rem;
    padding: 0.6rem 0.8rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .vault-select:focus {
    border-color: var(--gold);
  }

  /* Dropzone */
  .vault-dropzone {
    border: 2px dashed var(--border);
    padding: 3rem 2rem;
    text-align: center;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }

  :global(.vault-dropzone--active) {
    border-color: var(--gold) !important;
    background: var(--gold-glow) !important;
  }

  .vault-dropzone:hover {
    border-color: var(--border-light);
  }

  .vault-dropzone-icon {
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .vault-dropzone-text {
    font-size: 0.95rem;
    color: var(--cream-dim);
    margin-bottom: 0.4rem;
  }

  .vault-dropzone-hint {
    font-size: 0.75rem;
    color: var(--cream-muted);
    margin-bottom: 1.25rem;
  }

  .vault-browse-btn {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--cream-dim);
    padding: 0.5rem 1.2rem;
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .vault-browse-btn:hover {
    border-color: var(--gold-border);
  }

  /* Progress */
  .vault-progress {
    margin-top: 1rem;
  }

  .vault-progress-bar {
    height: 4px;
    background: var(--border);
    overflow: hidden;
  }

  .vault-progress-fill {
    height: 100%;
    background: var(--gold);
    transition: width 0.2s;
    width: 0%;
  }

  .vault-progress-text {
    font-size: 0.75rem;
    color: var(--cream-muted);
    margin-top: 0.5rem;
    text-align: center;
  }

  /* Error */
  .vault-error {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #c0886a;
    padding: 0.6rem 0.8rem;
    border: 1px solid rgba(192, 136, 106, 0.25);
    background: rgba(192, 136, 106, 0.06);
  }

  /* Result */
  .vault-result {
    margin-top: 1.25rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .vault-result-label {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .vault-result-url-row {
    display: flex;
    gap: 0.5rem;
  }

  .vault-result-url {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--cream);
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.8rem;
    padding: 0.6rem 0.8rem;
    outline: none;
  }

  .vault-copy-btn {
    background: var(--gold);
    border: none;
    color: var(--bg);
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1rem;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .vault-copy-btn:hover {
    background: var(--gold-light);
  }

  .vault-copy-feedback {
    font-size: 0.72rem;
    color: var(--gold);
    margin-top: 0.4rem;
  }

  /* History */
  .vault-history {
    margin-top: 1rem;
  }

  .vault-history-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--cream);
    margin-bottom: 1rem;
  }

  .vault-history-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.vault-history-item) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
  }

  :global(.vault-history-item:last-child) {
    border-bottom: 1px solid var(--border);
  }

  :global(.vault-history-name) {
    flex: 1;
    color: var(--cream-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.vault-history-category) {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  :global(.vault-history-time) {
    color: var(--cream-muted);
    font-size: 0.75rem;
  }

  :global(.vault-history-copy) {
    background: none;
    border: 1px solid var(--border);
    color: var(--cream-muted);
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }

  :global(.vault-history-copy:hover) {
    border-color: var(--gold-border);
    color: var(--cream);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .vault-page {
      padding: 6rem 1.5rem 3rem;
    }

    .vault-header {
      flex-direction: column;
      gap: 1rem;
    }

    .vault-result-url-row {
      flex-direction: column;
    }

    :global(.vault-history-item) {
      flex-wrap: wrap;
    }
  }
</style>
