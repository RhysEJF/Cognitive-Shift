---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCrest from '../components/HeroCrest.astro';
import GoldRule from '../components/GoldRule.astro';
import SignupToggle from '../components/SignupToggle.astro';
---
<BaseLayout>
  <main>
  <section class="hero" aria-label="Hero">
    <canvas id="starlings-canvas"></canvas>
    <div class="hero-content">
      <HeroCrest />

      <div class="hero-eyebrow">For <span id="typed-role"></span><span class="typed-cursor">|</span></div>

      <h1 class="hero-title">Nature solved <em>distributed intelligence</em> millions of years ago. Now it's your turn.</h1>

      <p class="hero-body">
        AI workforces are about to absorb the grind. This is where you figure out what's left. And what to do with it.
      </p>

      <GoldRule />

      <SignupToggle id="hero" />
    </div>
  </section>

  <!-- Below-the-fold -->
  <section class="below-fold" aria-label="About the shift">
    <div class="below-fold-split">
      <div class="below-fold-visual">
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Outer structure dissolving -->
          <path d="M200 40 L360 200 L200 360 L40 200 Z" stroke="#c8a45c" stroke-width="0.5" opacity="0.15"/>
          <path d="M200 80 L320 200 L200 320 L80 200 Z" stroke="#c8a45c" stroke-width="0.5" opacity="0.2"/>
          <path d="M200 120 L280 200 L200 280 L120 200 Z" stroke="#c8a45c" stroke-width="0.8" opacity="0.3"/>
          <!-- Network nodes -->
          <circle cx="200" cy="120" r="4" fill="#c8a45c" opacity="0.7"/>
          <circle cx="280" cy="200" r="4" fill="#c8a45c" opacity="0.7"/>
          <circle cx="200" cy="280" r="4" fill="#c8a45c" opacity="0.7"/>
          <circle cx="120" cy="200" r="4" fill="#c8a45c" opacity="0.7"/>
          <circle cx="200" cy="200" r="6" fill="#c8a45c" opacity="0.9"/>
          <!-- Connection lines -->
          <line x1="200" y1="120" x2="280" y2="200" stroke="#c8a45c" stroke-width="0.5" opacity="0.25"/>
          <line x1="280" y1="200" x2="200" y2="280" stroke="#c8a45c" stroke-width="0.5" opacity="0.25"/>
          <line x1="200" y1="280" x2="120" y2="200" stroke="#c8a45c" stroke-width="0.5" opacity="0.25"/>
          <line x1="120" y1="200" x2="200" y2="120" stroke="#c8a45c" stroke-width="0.5" opacity="0.25"/>
          <!-- Cross connections -->
          <line x1="200" y1="120" x2="200" y2="280" stroke="#c8a45c" stroke-width="0.3" opacity="0.15"/>
          <line x1="120" y1="200" x2="280" y2="200" stroke="#c8a45c" stroke-width="0.3" opacity="0.15"/>
          <!-- Scattered outer nodes -->
          <circle cx="140" cy="100" r="2.5" fill="#c8a45c" opacity="0.35"/>
          <circle cx="300" cy="140" r="2" fill="#c8a45c" opacity="0.25"/>
          <circle cx="320" cy="280" r="2.5" fill="#c8a45c" opacity="0.3"/>
          <circle cx="90" cy="300" r="2" fill="#c8a45c" opacity="0.25"/>
          <circle cx="260" cy="100" r="1.5" fill="#c8a45c" opacity="0.2"/>
          <circle cx="100" cy="260" r="1.5" fill="#c8a45c" opacity="0.2"/>
          <!-- Faint drift lines -->
          <line x1="200" y1="120" x2="140" y2="100" stroke="#c8a45c" stroke-width="0.3" opacity="0.15" stroke-dasharray="4 4"/>
          <line x1="280" y1="200" x2="300" y2="140" stroke="#c8a45c" stroke-width="0.3" opacity="0.15" stroke-dasharray="4 4"/>
          <line x1="200" y1="280" x2="320" y2="280" stroke="#c8a45c" stroke-width="0.3" opacity="0.15" stroke-dasharray="4 4"/>
          <line x1="120" y1="200" x2="90" y2="300" stroke="#c8a45c" stroke-width="0.3" opacity="0.15" stroke-dasharray="4 4"/>
          <!-- Subtle pulse rings -->
          <circle cx="200" cy="200" r="24" stroke="#c8a45c" stroke-width="0.4" opacity="0.12"/>
          <circle cx="200" cy="200" r="60" stroke="#c8a45c" stroke-width="0.3" opacity="0.08"/>
        </svg>
      </div>
      <div class="below-fold-text">
        <h2 class="below-fold-title">Something structural is shifting. Most people are waiting for a playbook. We're writing it by doing.</h2>
        <p class="below-fold-body">Agentic swarms, distributed intelligence, human-AI coordination. This isn't just theoretical here. We deploy, we fail, we learn, we share. If you want to stay on the cutting edge of AI augmentation, you're in the right place.</p>
      </div>
    </div>
  </section>

  <!-- Bottom Quote -->
  <section class="bottom-cta" aria-label="Quote">
    <div class="bottom-epigraph">&ldquo;You set the vision. They run with it. That&rsquo;s the shift.&rdquo;</div>
    <div class="bottom-attribution">&mdash; <a href="https://x.com/virtual_rf" target="_blank" rel="noopener">Rhys Fisher</a></div>
  </section>

  </main>

  <script is:inline>
  (function() {
    var words = ['operators', 'scientists', 'builders', 'philosophers', 'leaders'];
    var el = document.getElementById('typed-role');
    if (!el) return;
    var wordIndex = 0;
    var charIndex = 0;
    var deleting = false;
    var typeSpeed = 100;
    var deleteSpeed = 60;
    var pauseAfterType = 2000;
    var pauseAfterDelete = 400;

    function tick() {
      var current = words[wordIndex];
      if (!deleting) {
        el.textContent = current.slice(0, charIndex + 1);
        charIndex++;
        if (charIndex === current.length) {
          setTimeout(function() { deleting = true; tick(); }, pauseAfterType);
          return;
        }
        setTimeout(tick, typeSpeed);
      } else {
        charIndex--;
        el.textContent = current.slice(0, charIndex);
        if (charIndex === 0) {
          deleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          setTimeout(tick, pauseAfterDelete);
          return;
        }
        setTimeout(tick, deleteSpeed);
      }
    }
    tick();
  })();
  </script>
  <script src="/js/starlings.js" is:inline></script>
</BaseLayout>
