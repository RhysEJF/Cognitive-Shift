---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldRule from '../../components/GoldRule.astro';
import SignupToggle from '../../components/SignupToggle.astro';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications', ({ data }) => data.isActive))
  .sort((a, b) => a.data.order - b.data.order);
const authors = await getCollection('authors');

function getAuthor(slug: string) {
  return authors.find(a => a.id === slug);
}
---
<BaseLayout
  title="Publications — The Cognitive Shift"
  description="Written explorations of the structural AI shifts reshaping industries, workforces, and what it means to be AI augmented."
  ogUrl="https://thecognitiveshift.com/publications/"
>
  <header class="page-header">
    <div class="section-label">Observatory</div>
    <h1 class="page-title">Publications</h1>
    <p class="page-subtitle">
      Written explorations of the structural AI shifts reshaping industries, workforces, and what it means to be AI augmented.
    </p>
  </header>

  <div class="cream-band">
    <GoldRule />

    <section class="content-section pub-section">
      {publications.length === 0 ? (
        <p class="pub-empty">No publications yet. Check back soon.</p>
      ) : (
        <div class="pub-grid">
          {publications.map((pub) => {
            const author = getAuthor(pub.data.owner);
            return (
              <a href={`/publications/${pub.id}/`} class="pub-card">
                {author?.data.avatar && (
                  <div class="pub-card-avatar">
                    <img src={author.data.avatar} alt={author.data.name} loading="lazy" />
                  </div>
                )}
                <div class="pub-card-name">{pub.data.name}</div>
                {pub.data.description && (
                  <div class="pub-card-description">{pub.data.description}</div>
                )}
                <div class="pub-card-meta">
                  <span class="pub-card-owner">
                    {author ? author.data.name : pub.data.owner.replace(/-/g, ' ')}
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </section>

    <!-- Bottom CTA -->
    <section class="bottom-cta">
      <SignupToggle id="pub-index" />
    </section>
  </div>
</BaseLayout>
