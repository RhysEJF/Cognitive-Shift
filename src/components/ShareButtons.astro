---
interface Props {
  title: string;
  url: string;
  articleId: string;
}

const { title, url, articleId } = Astro.props;

// Encode the content for sharing
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

// Social share URLs
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const substackUrl = `https://substack.com/inbox/post/new?utm_source=share&title=${encodedTitle}&url=${encodedUrl}`;
---

<div class="share-engagement">
  <div class="share-buttons">
    <!-- Substack -->
    <a
      href={substackUrl}
      target="_blank"
      rel="noopener"
      class="share-btn substack"
      title="Share on Substack"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
      </svg>
    </a>

    <!-- Twitter/X -->
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener"
      class="share-btn twitter"
      title="Share on X"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener"
      class="share-btn linkedin"
      title="Share on LinkedIn"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Facebook -->
    <a
      href={facebookUrl}
      target="_blank"
      rel="noopener"
      class="share-btn facebook"
      title="Share on Facebook"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>
  </div>

  <!-- Like Button -->
  <div class="engagement-actions">
    <button
      class="like-btn"
      data-article-id={articleId}
      title="Like this article"
    >
      <svg class="like-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="like-count">0</span>
    </button>

    <!-- Comments Link -->
    <a href="#comments" class="comment-btn" title="Jump to comments">
      <svg class="comment-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="comment-text">Comments</span>
    </a>
  </div>
</div>

<script>
// Share button functionality
document.addEventListener('DOMContentLoaded', () => {

  // Like button functionality
  const likeButton = document.querySelector('.like-btn');
  if (likeButton) {
    const articleId = likeButton.getAttribute('data-article-id');
    const likeCount = likeButton.querySelector('.like-count');
    const storageKey = `liked-${articleId}`;

    // Check if already liked
    const hasLiked = localStorage.getItem(storageKey) === 'true';
    if (hasLiked) {
      likeButton.classList.add('liked');
    }

    // Load current like count
    loadLikeCount(articleId, likeCount);

    // Handle like click
    likeButton.addEventListener('click', async () => {
      if (hasLiked) {
        return; // Already liked, do nothing
      }

      try {
        const response = await fetch('/api/likes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ articleId })
        });

        if (response.ok) {
          const data = await response.json();
          likeCount.textContent = data.likes;
          likeButton.classList.add('liked');
          localStorage.setItem(storageKey, 'true');
        }
      } catch (err) {
        console.error('Failed to like article:', err);
      }
    });
  }
});

async function loadLikeCount(articleId, countElement) {
  try {
    const response = await fetch(`/api/likes?articleId=${articleId}`);
    if (response.ok) {
      const data = await response.json();
      countElement.textContent = data.likes;
    }
  } catch (err) {
    console.error('Failed to load like count:', err);
  }
}
</script>

<style>
.share-engagement {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1rem 0;
  margin: 1.5rem 0;
}

.share-buttons {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--cream-bg);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
}

.share-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.share-icon {
  width: 18px;
  height: 18px;
}

/* Platform-specific hover colors */
.share-btn.substack:hover {
  background: #FF6719;
  color: white;
  border-color: #FF6719;
}

.share-btn.twitter:hover {
  background: #1DA1F2;
  color: white;
  border-color: #1DA1F2;
}

.share-btn.linkedin:hover {
  background: #0077B5;
  color: white;
  border-color: #0077B5;
}

.share-btn.facebook:hover {
  background: #1877F2;
  color: white;
  border-color: #1877F2;
}

/* Engagement Actions */
.engagement-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--cream-bg);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 0.85rem;
}

.like-btn:hover {
  background: #ffe0e0;
  border-color: #ff6b6b;
  color: #ff6b6b;
}

.like-btn.liked {
  background: #ff6b6b;
  border-color: #ff6b6b;
  color: white;
}

.like-btn.liked .like-icon {
  fill: white;
}

.like-icon {
  width: 16px;
  height: 16px;
}

.comment-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--cream-bg);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s ease;
  font-size: 0.85rem;
}

.comment-btn:hover {
  background: var(--panel);
  border-color: var(--gold);
  color: var(--text-dark);
}

.comment-icon {
  width: 16px;
  height: 16px;
}

/* Responsive */
@media (max-width: 600px) {
  .share-engagement {
    flex-direction: column;
    gap: 1rem;
  }

  .share-btn {
    width: 36px;
    height: 36px;
  }

  .share-icon {
    width: 16px;
    height: 16px;
  }

  .like-btn, .comment-btn {
    font-size: 0.8rem;
    padding: 0.4rem 0.7rem;
  }
}
</style>