---
interface Props {
  title: string;
  url: string;
  articleId: string;
}

const { title, url, articleId } = Astro.props;

// Encode the content for sharing
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

// Social share URLs
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const redditUrl = `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`;
const emailUrl = `mailto:?subject=${encodedTitle}&body=${encodedTitle}%0A%0A${encodedUrl}`;
const telegramUrl = `https://telegram.me/share/url?url=${encodedUrl}&text=${encodedTitle}`;
const whatsappUrl = `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`;
---

<div class="share-engagement">
  <div class="share-buttons">
    <!-- Reddit -->
    <a
      href={redditUrl}
      target="_blank"
      rel="noopener"
      class="share-btn reddit"
      title="Share on Reddit"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
      </svg>
    </a>

    <!-- Twitter/X -->
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener"
      class="share-btn twitter"
      title="Share on X"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener"
      class="share-btn linkedin"
      title="Share on LinkedIn"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Facebook -->
    <a
      href={facebookUrl}
      target="_blank"
      rel="noopener"
      class="share-btn facebook"
      title="Share on Facebook"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <!-- Email -->
    <a
      href={emailUrl}
      class="share-btn email"
      title="Share via Email"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
      </svg>
    </a>

    <!-- Telegram -->
    <a
      href={telegramUrl}
      target="_blank"
      rel="noopener"
      class="share-btn telegram"
      title="Share on Telegram"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
    </a>

    <!-- WhatsApp -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener"
      class="share-btn whatsapp"
      title="Share on WhatsApp"
    >
      <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
      </svg>
    </a>
  </div>

  <!-- Like Button -->
  <div class="engagement-actions">
    <button
      class="like-btn"
      data-article-id={articleId}
      title="Like this article"
    >
      <svg class="like-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="like-count">0</span>
    </button>

    <!-- Comments Link -->
    <a href="#comments" class="comment-btn" title="Jump to comments">
      <svg class="comment-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="comment-text">Comments</span>
    </a>
  </div>
</div>

<script>
// Share button functionality
document.addEventListener('DOMContentLoaded', () => {

  // Like button functionality
  const likeButton = document.querySelector('.like-btn');
  if (likeButton) {
    const articleId = likeButton.getAttribute('data-article-id');
    const likeCount = likeButton.querySelector('.like-count');
    const storageKey = `liked-${articleId}`;

    // Check if already liked
    const hasLiked = localStorage.getItem(storageKey) === 'true';
    if (hasLiked) {
      likeButton.classList.add('liked');
    }

    // Load current like count
    loadLikeCount(articleId, likeCount);

    // Handle like click
    likeButton.addEventListener('click', async () => {
      if (hasLiked) {
        return; // Already liked, do nothing
      }

      try {
        const response = await fetch('/api/likes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ articleId })
        });

        if (response.ok) {
          const data = await response.json();
          likeCount.textContent = data.likes;
          likeButton.classList.add('liked');
          localStorage.setItem(storageKey, 'true');
        }
      } catch (err) {
        console.error('Failed to like article:', err);
      }
    });
  }
});

async function loadLikeCount(articleId, countElement) {
  try {
    const response = await fetch(`/api/likes?articleId=${articleId}`);
    if (response.ok) {
      const data = await response.json();
      countElement.textContent = data.likes;
    }
  } catch (err) {
    console.error('Failed to load like count:', err);
  }
}
</script>

<style>
.share-engagement {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1rem 0;
  margin: 1.5rem 0;
}

.share-buttons {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--cream-bg);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
}

.share-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.share-icon {
  width: 18px;
  height: 18px;
}

/* Platform-specific hover colors */
.share-btn.reddit:hover {
  background: #FF4500;
  color: white;
  border-color: #FF4500;
}

.share-btn.twitter:hover {
  background: #1DA1F2;
  color: white;
  border-color: #1DA1F2;
}

.share-btn.linkedin:hover {
  background: #0077B5;
  color: white;
  border-color: #0077B5;
}

.share-btn.facebook:hover {
  background: #1877F2;
  color: white;
  border-color: #1877F2;
}

.share-btn.email:hover {
  background: #34495e;
  color: white;
  border-color: #34495e;
}

.share-btn.telegram:hover {
  background: #0088cc;
  color: white;
  border-color: #0088cc;
}

.share-btn.whatsapp:hover {
  background: #25D366;
  color: white;
  border-color: #25D366;
}

/* Engagement Actions */
.engagement-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--cream-bg);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 0.85rem;
}

.like-btn:hover {
  background: #fff4e6;
  border-color: #FF6719;
  color: #FF6719;
}

.like-btn.liked {
  background: #FF6719;
  border-color: #FF6719;
  color: white;
}

.like-btn.liked .like-icon {
  fill: white;
}

.like-icon {
  width: 16px;
  height: 16px;
}

.comment-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--cream-bg);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s ease;
  font-size: 0.85rem;
}

.comment-btn:hover {
  background: var(--panel);
  border-color: var(--gold);
  color: var(--text-dark);
}

.comment-icon {
  width: 16px;
  height: 16px;
}

/* Responsive */
@media (max-width: 600px) {
  .share-engagement {
    flex-direction: column;
    gap: 1rem;
  }

  .share-btn {
    width: 36px;
    height: 36px;
  }

  .share-icon {
    width: 16px;
    height: 16px;
  }

  .like-btn, .comment-btn {
    font-size: 0.8rem;
    padding: 0.4rem 0.7rem;
  }
}
</style>