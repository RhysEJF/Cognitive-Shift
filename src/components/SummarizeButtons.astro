---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

// Generate prompts for different AI platforms
const chatgptPrompt = `Read and summarize this article "${title}" ${url}`;
const claudePrompt = `Please read and provide a concise summary of this article: "${title}" from ${url}`;
const geminiPrompt = `Summarize this article for me: "${title}" - ${url}`;
const perplexityPrompt = `Can you read and summarize: "${title}" ${url}`;

// Encode the prompts for URL parameters
const encodedChatGPT = encodeURIComponent(chatgptPrompt);
const encodedClaude = encodeURIComponent(claudePrompt);
const encodedGemini = encodeURIComponent(geminiPrompt);
const encodedPerplexity = encodeURIComponent(perplexityPrompt);
---

<div class="summarize-buttons">
  <div class="summarize-label">Summarize in</div>
  <div class="summarize-options">
    <a
      href={`https://chatgpt.com/?prompt=${encodedChatGPT}`}
      target="_blank"
      rel="noopener"
      class="summarize-btn summarize-chatgpt"
    >
      <svg class="summarize-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/>
      </svg>
      ChatGPT
    </a>

    <a
      href={`https://claude.ai/chat?q=${encodedClaude}`}
      target="_blank"
      rel="noopener"
      class="summarize-btn summarize-claude"
    >
      <svg class="summarize-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M7.307 2.5c-.729 0-1.434.29-1.952.808-.519.518-.808 1.223-.808 1.952v13.48c0 .729.289 1.434.808 1.952.518.518 1.223.808 1.952.808h9.386c.729 0 1.434-.29 1.952-.808.519-.518.808-1.223.808-1.952V5.26c0-.729-.289-1.434-.808-1.952-.518-.518-1.223-.808-1.952-.808H7.307zm2.625 4.167c0-.46.373-.833.834-.833h2.468c.46 0 .833.373.833.833s-.373.833-.833.833h-2.468c-.461 0-.834-.373-.834-.833zm0 2.5c0-.46.373-.833.834-.833h2.468c.46 0 .833.373.833.833s-.373.833-.833.833h-2.468c-.461 0-.834-.373-.834-.833zm0 2.5c0-.46.373-.833.834-.833h2.468c.46 0 .833.373.833.833s-.373.833-.833.833h-2.468c-.461 0-.834-.373-.834-.833z"/>
      </svg>
      Claude
    </a>

    <a
      href={`https://gemini.google.com/?q=${encodedGemini}`}
      target="_blank"
      rel="noopener"
      class="summarize-btn summarize-gemini"
    >
      <svg class="summarize-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L13.09 8.26L22 9L13.09 9.74L12 16L10.91 9.74L2 9L10.91 8.26L12 2Z"/>
      </svg>
      Gemini
    </a>

    <a
      href={`https://www.perplexity.ai/?q=${encodedPerplexity}`}
      target="_blank"
      rel="noopener"
      class="summarize-btn summarize-perplexity"
    >
      <svg class="summarize-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
      </svg>
      Perplexity
    </a>
  </div>
</div>

<style>
.summarize-buttons {
  margin: 2rem 0;
  text-align: center;
}

.summarize-label {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 1rem;
  letter-spacing: 0.05em;
}

.summarize-options {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem;
}

.summarize-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border: 1px solid var(--border-cream);
  border-radius: 20px;
  background: #f8f6f2;
  color: var(--text-body);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 500;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.summarize-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.summarize-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

/* Platform-specific colors */
.summarize-chatgpt {
  border-color: #74aa9c;
}

.summarize-chatgpt:hover {
  background: #74aa9c;
  border-color: #74aa9c;
  color: white;
}

.summarize-claude {
  border-color: #cc785c;
}

.summarize-claude:hover {
  background: #cc785c;
  border-color: #cc785c;
  color: white;
}

.summarize-gemini {
  border-color: #4285f4;
}

.summarize-gemini:hover {
  background: #4285f4;
  border-color: #4285f4;
  color: white;
}

.summarize-perplexity {
  border-color: #1fb8cd;
}

.summarize-perplexity:hover {
  background: #1fb8cd;
  border-color: #1fb8cd;
  color: white;
}

/* Responsive */
@media (max-width: 600px) {
  .summarize-options {
    gap: 0.5rem;
  }

  .summarize-btn {
    padding: 0.5rem 0.8rem;
    font-size: 0.8rem;
  }

  .summarize-icon {
    width: 14px;
    height: 14px;
  }
}
</style>